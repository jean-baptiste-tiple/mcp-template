# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Supabase (ajouter après activation du starter supabase-auth)
# ============================================
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_PROJECT_ID=your-project-id

# ============================================
# IA — Claude API (si le projet utilise l'IA)
# ============================================
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Canal MCP (serveur /api/mcp — OAuth 2.1)
# ============================================
# Auth = Supabase OAuth 2.1 Server (config côté dashboard Supabase : OAuth Server + DCR
# + redirect URIs Claude/ChatGPT). Rien à ajouter ici.
# URL canonique du serveur MCP (metadata RFC 9728) :
# MCP_RESOURCE_URL=https://mon-produit.example/api/mcp
# Transport stateful UNIQUEMENT (sessions/SSE — voir starter mcp + ADR transport) :
# REDIS_URL=rediss://...
